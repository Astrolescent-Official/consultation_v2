# Test backend: use the PlanetScale `test` development branch connection URL.
# Keep this file as a template; copy it to the ignored `.env.test` file.
DATABASE_URL='postgresql://ROLE:PASSWORD@HOST:6432/DATABASE?sslmode=verify-full&sslrootcert=system'
NETWORK_ID=2
ENV=test
POLL_SCHEDULE='rate(5 minutes)'
POLL_TIMEOUT_DURATION='120 seconds'
