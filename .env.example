DATABASE_URL=postgresql://postgres:postgres@localhost:5432/consultation
NETWORK_ID=2
ENV=development
POLL_SCHEDULE='rate(5 minutes)'
POLL_TIMEOUT_DURATION='120 seconds'

# Docker deployment — domains & TLS
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
CERTBOT_EMAIL=admin@example.com
CERTBOT_STAGING=0

# Consultation dApp build args
VITE_PUBLIC_DAPP_DEFINITION_ADDRESS=
VITE_PUBLIC_NETWORK_ID=2
